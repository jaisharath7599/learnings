--COPY INTO
--COPY INTO is a SQL command in Databricks used to incrementally load data from external storage into a Delta table (like ADLS, S3, etc.).
--frist we need to create a empty delta table
CREATE TABLE delta_table
--run copty into command
COPY INTO delta_table
FROM 's3://bucket_name/path/'
FILEFORMAT = 'parquet'
copy_options ('mergeSchema' = 'true');
-- mergeSchema = true option allows the COPY INTO command to automatically merge the schema of the incoming data with the existing schema of the Delta table. 
-- if we rerun the COPY INTO command again it will not copy the data again because its already copied.

------------------------------------------------------------------------

--INSERT OVERWRITE
--INSERT OVERWRITE is a SQL command used to replace the existing data in a table with new data. 
-- it will work same as CRAS command but the difference is CRAS can alter source table schema but INSERT OVERWRITE will not alter the source table schema.
INSERT OVERWRITE TABLE target_table
SELECT * FROM source_table;

------------------------------------------------------------------------

--MERGE INTO
--MERGE INTO is a SQL command used to perform an upsert operation, which means it can insert new records, update existing records, or delete records based on a specified condition.
MERGE INTO target_table AS target
USING source_table AS source
ON target.id = source.id
WHEN MATCHED THEN 
    UPDATE SET target.name = source.name, target.age = source.age
WHEN NOT MATCHED THEN 
    INSERT (id, name, age) VALUES (source.id, source.name, source.age)
WHEN NOT MATCHED BY SOURCE THEN 
    DELETE;

