--PIVOT AND UNPIVOT
--PIVOT: The PIVOT function is used to rotate rows into columns. It allows you to aggregate data and display it in a more readable format.
SELECT *
FROM (
    SELECT department, name, salary
    FROM employees
) AS source
PIVOT (
    SUM(salary)
    FOR name IN ('Arun', 'Ravi', 'Meena')
) AS pivot_table;

