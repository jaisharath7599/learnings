-- ARRAY MANIPULATION
🔹 input
id	name	department	skills
1	Arun	IT	["Python","SQL"]
2	Ravi	IT	["SQL","Spark"]
3	Meena	HR	["Excel","Recruit"]

-- 1. EXPLODE: The EXPLODE function is used to transform an array into a set of rows. Each element of the array becomes a separate row in the output.
SELECT id, name, EXPLODE(skills) AS skill
FROM employees;

🔹 Output
id	name	skill
1	Arun	Python
1	Arun	SQL
2	Ravi	SQL
2	Ravi	Spark
3	Meena	Excel
3	Meena	Recruit

-- 2. COLLECT_SET: The COLLECT_SET function is used to aggregate values into an array while eliminating duplicates. It collects unique values from a group of rows and returns them as an array.
SELECT department, COLLECT_SET(name) AS unique_names
FROM employees
GROUP BY department;
🔹 Output
department	unique_names
IT	["Arun","Ravi"]
HR	["Meena"]

-- 3. FLATTEN: The FLATTEN function is used to transform a nested array into a set of rows. It is similar to EXPLODE but can handle nested arrays.
SELECT id, name, FLATTEN(skills) AS skill
FROM employees;
🔹 input
id	name	skills
1	Arun	[["Python","SQL"],["Spark"]]
2	Ravi	[["Java"],["SQL","Scala"]]
🔹 Output
id	name	skill
1	Arun	["Python","SQL","Spark"]
2	Ravi	["Java","SQL","Scala"]

