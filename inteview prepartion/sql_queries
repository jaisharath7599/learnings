--GENERATED COLUMNS
-- this are a special type of column whole values are automatically generated based on an expression or a sequence.
CREATE TABLE employees (
    id INT,
    name STRING,
    salary DOUBLE,
    tax DOUBLE GENERATED ALWAYS AS (salary * 0.2) STORED
);
-- In this example, the tax column is a generated column that calculates the tax based on the salary column. 

-- this won't work when we do merge by default, so to generate it:
-- run --> SET spark.databricks.delta.schema.autoMerge.enabled = true;

