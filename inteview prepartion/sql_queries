--CONSTRAINTS
--currently databricks suppoert only NOT NULL and CHECK constraints.
--NOT NULL constraint ensures that a column cannot have a NULL value.
--CHECK constraint allows you to specify a condition that must be true for each row in the table.

CREATE TABLE employees (
    id INT NOT NULL,
    name STRING NOT NULL,
    age INT CHECK (age >= 18)
);
-- In this example, the id and name columns cannot have NULL values, and the age column must be greater than or equal to 18.

